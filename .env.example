# copy to .env.local and fill in
POSTGRES_PASSWORD=change-me
GEMINI_API_KEY=
# WhatsApp Cloud API (leave empty until F1 is wired)
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# demo-inject endpoint guard
DEMO_INJECT_TOKEN=change-me
# Google Maps JS API key (referrer-restricted; baked into frontend build)
VITE_MAPS_API_KEY=
# Twilio (WhatsApp sandbox): needed to download media with basic auth
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
